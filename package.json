{
  "name": "potato",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @potato/cli build",
    "build:npm:cli": "node scripts/build-npm-cli.mjs",
    "dev": "pnpm --filter @potato/cli dev",
    "test": "pnpm --filter @potato/cli test && node --test scripts/tests/*.test.mjs",
    "typecheck": "pnpm --filter @potato/cli typecheck"
  },
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "esbuild": "0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
